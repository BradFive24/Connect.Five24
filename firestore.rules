rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - userId: string
    //   - placeId: string
    //   - source: map (read-only from user perspective, but rules allow write on create)
    //   - crm: map (editable by user)
    //   - compliance: map
    //
    // Collection: users
    // Document ID: user email
    // Fields:
    //   - onboardingCompleted: boolean (required)
    //   - projectId: string (optional)
    //   - updatedAt: string (required, ISO 8601)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "brad@524-photo.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isValidLead(data) {
      return data.id is string &&
             data.userId is string &&
             data.placeId is string &&
             data.source is map &&
             data.source.name is string &&
             data.source.formattedAddress is string &&
             data.source.location is map &&
             data.source.lastSynced is string &&
             data.crm is map &&
             data.crm.status in ['new', 'contacted', 'follow-up', 'closed'] &&
             data.crm.interactionHistory is list &&
             data.compliance is map &&
             data.compliance.verifiedByEU is bool &&
             data.compliance.collectedAt is string;
    }

    function isValidUser(data) {
      return data.onboardingCompleted is bool &&
             data.updatedAt is string;
    }

    match /leads/{leadId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isValidLead(request.resource.data) && (isOwner(request.resource.data.userId) || isAdmin());
      allow update: if isAuthenticated() && 
                     isValidLead(request.resource.data) && 
                     (isOwner(resource.data.userId) || isAdmin()) && 
                     (request.resource.data.userId == resource.data.userId) &&
                     (request.resource.data.source == resource.data.source) &&
                     (request.resource.data.placeId == resource.data.placeId);
      allow delete: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
    }

    match /users/{email} {
      allow read: if isAuthenticated() && (request.auth.token.email == email || isAdmin());
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.auth.token.email == email || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (request.auth.token.email == email || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
