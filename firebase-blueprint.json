{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A sales lead with Google source data and user-owned CRM data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "placeId": { "type": "string" },
        "source": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "formattedAddress": { "type": "string" },
            "phoneNumber": { "type": "string" },
            "rating": { "type": "number" },
            "userRatingCount": { "type": "number" },
            "location": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "lastSynced": { "type": "string", "format": "date-time" }
          }
        },
        "crm": {
          "type": "object",
          "properties": {
            "ownerName": { "type": "string" },
            "managerName": { "type": "string" },
            "email": { "type": "string" },
            "notes": { "type": "string" },
            "status": { "type": "string", "enum": ["new", "contacted", "qualified", "proposal", "closed", "lost", "rejected"] },
            "tags": { "type": "array", "items": { "type": "string" } },
            "interactionHistory": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "type": { "type": "string", "enum": ["call", "visit", "note", "status_change", "email", "appointment", "reminder"] },
                  "content": { "type": "string" },
                  "timestamp": { "type": "string", "format": "date-time" },
                  "dueDate": { "type": "string", "format": "date-time" },
                  "completed": { "type": "boolean" }
                }
              }
            },
            "nextStep": { "type": "string" },
            "lastContacted": { "type": "string", "format": "date-time" }
          }
        },
        "compliance": {
          "type": "object",
          "properties": {
            "verifiedByEU": { "type": "boolean" },
            "collectedAt": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["id", "userId", "placeId", "source", "crm", "compliance"]
    },
    "User": {
      "title": "User",
      "description": "User profile and onboarding status.",
      "type": "object",
      "properties": {
        "onboardingCompleted": { "type": "boolean" },
        "projectId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["onboardingCompleted", "updatedAt"]
    }
  },
  "firestore": {
    "leads": {
      "schema": "Lead",
      "description": "Collection of sales leads."
    },
    "users": {
      "schema": "User",
      "description": "User profiles and onboarding status."
    }
  }
}
